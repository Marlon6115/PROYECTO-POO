<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<Pane prefHeight="600.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyectopoo.controller.LoginController">

   <children>

      <Rectangle height="55.0" style="-fx-fill: #212529;" width="700.0" x="0.0" y="0.0" />

      <Label layoutX="20.0" layoutY="12.0" style="-fx-text-fill: white;" text="Gestor de Estudiantes">
         <font>
            <Font size="22.0" />
         </font>
      </Label>

      <Label layoutX="267.0" layoutY="101.0" text="INICIAR SESIÓN">
         <font>
            <Font name="System Bold" size="22.0" />
         </font>
      </Label>

      <Label layoutX="220.0" layoutY="180.0" text="Usuario">
         <font>
            <Font size="14.0" />
         </font>
      </Label>

      <TextField fx:id="txtUsuario" layoutX="220.0" layoutY="210.0" prefHeight="35.0" prefWidth="298.0" promptText="Ingrese su usuario" />

      <Label layoutX="220.0" layoutY="270.0" text="Contraseña">
         <font>
            <Font size="14.0" />
         </font>
      </Label>

      <PasswordField fx:id="txtPassword" layoutX="220.0" layoutY="295.0" prefHeight="35.0" prefWidth="298.0" promptText="Ingrese su contraseña" />

      <Button fx:id="btnLogin" layoutX="208.0" layoutY="471.0" mnemonicParsing="false" onAction="#iniciarSesion" prefHeight="40.0" prefWidth="321.0" text="Ingresar" />

      <Button fx:id="btnSalir" layoutX="207.0" layoutY="532.0" mnemonicParsing="false" onAction="#salir" prefHeight="35.0" prefWidth="321.0" text="Salir" />

      <Label fx:id="lblMensaje" layoutX="220.0" layoutY="433.0" prefHeight="17.0" prefWidth="298.0" textFill="RED" />
      <ComboBox fx:id="cbRol" layoutX="220.0" layoutY="376.0" prefHeight="35.0" prefWidth="298.0" promptText="Seleccione..." />
      <Label layoutX="221.0" layoutY="349.0" text="Rol">
         <font>
            <Font size="14.0" />
         </font>
      </Label>

   </children>

</Pane>
