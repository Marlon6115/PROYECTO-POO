<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<Pane prefHeight="550.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyectopoo.controller.RegisterController">

   <children>

      <!-- Barra superior -->

      <Rectangle height="55.0" style="-fx-fill: #212529;" width="700.0" x="0.0" y="0.0" />

      <Label layoutX="20.0" layoutY="12.0" style="-fx-text-fill: white;" text="Gestor de Estudiantes">
         <font>
            <Font size="22.0" />
         </font>
      </Label>

      <!-- Título -->

      <Label layoutX="245.0" layoutY="90.0" text="REGISTRAR USUARIO">
         <font>
            <Font name="System Bold" size="22.0" />
         </font>
      </Label>

      <!-- Usuario -->

      <Label layoutX="221.0" layoutY="155.0" text="Usuario">
         <font>
            <Font size="14.0" />
         </font>
      </Label>

      <TextField fx:id="txtUsuario" layoutX="220.0" layoutY="182.0" prefHeight="35.0" prefWidth="298.0" promptText="Ingrese un usuario" />

      <!-- Contraseña -->

      <Label layoutX="221.0" layoutY="231.0" text="Contraseña">
         <font>
            <Font size="14.0" />
         </font>
      </Label>

      <PasswordField fx:id="txtClave" layoutX="219.0" layoutY="258.0" prefHeight="35.0" prefWidth="298.0" promptText="Ingrese una contraseña" />

      <!-- Rol -->

      <Label layoutX="221.0" layoutY="311.0" text="Rol">
         <font>
            <Font size="14.0" />
         </font>
      </Label>

      <ComboBox fx:id="cbRol" layoutX="219.0" layoutY="339.0" prefHeight="35.0" prefWidth="298.0" promptText="Seleccione..." />

      <!-- Mensaje -->

      <Label fx:id="lblMensaje" layoutX="219.0" layoutY="395.0" prefWidth="298.0" textFill="RED" />

      <!-- Botones -->

      <Button fx:id="btnRegistrar" layoutX="209.0" layoutY="432.0" mnemonicParsing="false" onAction="#registrar" prefHeight="40.0" prefWidth="321.0" text="Registrarse" />

      <Button fx:id="btnVolver" layoutX="209.0" layoutY="485.0" mnemonicParsing="false" onAction="#volver" prefHeight="35.0" prefWidth="321.0" text="Volver al Login" />

   </children>

</Pane>
