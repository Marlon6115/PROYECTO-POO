<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<Pane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyectopoo.controller.EstudianteController">

   <children>

      <Label layoutX="40.0" layoutY="80.0" text="Registro">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>

      <Label layoutX="40.0" layoutY="130.0" text="Cédula" />
      <TextField fx:id="txtCedula" layoutX="40.0" layoutY="155.0" prefHeight="35.0" prefWidth="320.0" />

      <Label layoutX="40.0" layoutY="220.0" text="Nombre" />
      <TextField fx:id="txtNombre" layoutX="40.0" layoutY="245.0" prefHeight="35.0" prefWidth="320.0" />

      <Label layoutX="40.0" layoutY="310.0" text="Apellido" />
      <TextField fx:id="txtApellido" layoutX="40.0" layoutY="335.0" prefHeight="35.0" prefWidth="320.0" />

      <Label layoutX="40.0" layoutY="400.0" text="Email" />
      <TextField fx:id="txtEmail" layoutX="40.0" layoutY="425.0" prefHeight="35.0" prefWidth="320.0" />

      <Label layoutX="40.0" layoutY="490.0" text="Carrera" />
      <ComboBox fx:id="cbCarrera" layoutX="40.0" layoutY="515.0" prefHeight="35.0" prefWidth="320.0" promptText="Seleccione..." />

      <Button fx:id="btnGuardar" layoutX="40.0" layoutY="575.0" onAction="#guardar" prefHeight="35.0" prefWidth="320.0" text="Guardar" />

      <Label layoutX="430.0" layoutY="80.0" text="Estudiantes Registrados">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>

      <TextField fx:id="txtBuscar" layoutX="430.0" layoutY="125.0" prefHeight="35.0" prefWidth="330.0" promptText="Buscar por cédula o nombre..." />

      <ComboBox fx:id="cbFiltroCarrera" layoutX="790.0" layoutY="125.0" prefHeight="35.0" prefWidth="220.0" promptText="Todas las carreras" />

      <Button fx:id="btnActualizar" layoutX="1040.0" layoutY="125.0" onAction="#actualizar" prefHeight="35.0" prefWidth="110.0" text="Actualizar" />

      <TableView fx:id="tablaEstudiantes" layoutX="430.0" layoutY="180.0" prefHeight="450.0" prefWidth="720.0">
         <columns>
            <TableColumn fx:id="colId" prefWidth="94.0" text="ID" />
            <TableColumn fx:id="colNombreCompleto" prefWidth="143.33331298828125" text="Cédula" />
            <TableColumn fx:id="colCarrera" prefWidth="157.99993896484375" text="Nombre Completo" />
            <TableColumn fx:id="colEmail" prefWidth="113.3333740234375" text="Email" />
            <TableColumn prefWidth="167.333251953125" text="Carrera" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>

      <Button fx:id="btnEliminar" layoutX="430.0" layoutY="650.0" onAction="#eliminar" prefWidth="100.0" text="Eliminar" />
      <Button fx:id="btnEditar" layoutX="550.0" layoutY="650.0" onAction="#editar" prefWidth="100.0" text="Editar" />
      <Button fx:id="btnSalir" layoutX="1050.0" layoutY="650.0" onAction="#salir" prefWidth="100.0" text="Salir" />
      <Rectangle height="55.0" style="-fx-fill: #212529;" width="1200.0" x="0.0" y="0.0" />
      <Label layoutX="14.0" layoutY="12.0" style="-fx-text-fill: white;" text="Gestor de Estudiantes">
         <font>
            <Font size="22.0" />
         </font>
      </Label>
      <Label fx:id="lblUsuario" layoutX="1005.0" layoutY="15.0" style="-fx-text-fill: white;" text="Usuario: ">
         <font>
            <Font size="18.0" />
         </font>
      </Label>

   </children>
</Pane>
